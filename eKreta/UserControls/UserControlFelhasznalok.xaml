<UserControl
    x:Class="eKreta.UserControls.UserControlFelhasznalok"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:eKreta.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel>
        <DataGrid
            x:Name="datagridFelhasznalok"
            Width="1000"
            Height="500"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            IsReadOnly="True"
            SelectionChanged="datagridFelhasznalok_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                <DataGridTextColumn Binding="{Binding FelhasznaloNev}" Header="Felhasználó név" />
                <DataGridTextColumn Binding="{Binding TeljesNev}" Header="Teljes név" />
                <DataGridTextColumn Binding="{Binding Jelszo}" Header="Jelszó" />
                <DataGridTextColumn Binding="{Binding Szerepkor}" Header="Szerepkör Id" />
                <DataGridTextColumn Binding="{Binding SzerepkorNev}" Header="Szerepkör név" />
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel Margin="130,10,130,0" VerticalAlignment="Center">
            <StackPanel Width="300">
                <TextBlock Text="Felhasználó név:" />
                <TextBox x:Name="felhasznaloNevTxtBx" />
                <TextBlock Text="Teljes név:" />
                <TextBox x:Name="teljesNevTxtBx" />
                <TextBlock Text="Jelszó:" />
                <PasswordBox x:Name="jelszoBx" />
                <TextBlock Text="Szerepkör:" />
                <ComboBox x:Name="szerepkor" />
            </StackPanel>
            <StackPanel>
                <Button
                    x:Name="mentesBtn"
                    Width="200"
                    Margin="20,10,0,0"
                    Background="Green"
                    Click="mentesBtn_Click"
                    Content="Mentés"
                    Foreground="White" />
                <Button
                    x:Name="torlesBtn"
                    Width="200"
                    Margin="20,10,0,0"
                    Background="Red"
                    Click="torlesBtn_Click"
                    Content="Törlés"
                    Foreground="White" />
                <Button
                    x:Name="modBth"
                    Width="200"
                    Margin="20,10,0,0"
                    Background="Yellow"
                    Click="modBth_Click"
                    Content="Módosítás" />
            </StackPanel>
        </WrapPanel>

    </StackPanel>
</UserControl>
